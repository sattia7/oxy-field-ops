{
  "version": 2,
  "name": "ai-field-ops",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "\/(m1-q[1-8].png|oxy-logo.svg|slb-logo.svg|File_OXY_LOGO.svg|SLB_Logo_2022.svg|favicon.ico)",
      "dest": "\/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "src": "\/(.*)",
      "dest": "\/index.html"
    }
  ]
}
